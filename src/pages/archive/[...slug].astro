---
import { render } from 'astro:content';
import { getEssaySlug, getVisibleEssayRouteEntries } from '../../lib/content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { createWithBase } from '../../utils/format';

export const prerender = true;

export async function getStaticPaths() {
  const base = import.meta.env.BASE_URL ?? '/';
  const withBase = createWithBase(base);
  const routeEntries = await getVisibleEssayRouteEntries();
  return routeEntries.map(({ slug, entry, prev, next }) => {
    return {
      params: { slug },
      props: {
        entry,
        prev: prev
          ? { href: withBase(`/archive/${getEssaySlug(prev)}/`), title: prev.data.title }
          : null,
        next: next
          ? { href: withBase(`/archive/${getEssaySlug(next)}/`), title: next.data.title }
          : null
      }
    };
  });
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<ArticleLayout entry={entry} Content={Content} prev={prev} next={next} />
